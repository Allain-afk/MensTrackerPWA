# Supabase project — also used for Google-authenticated cloud sync.
# Ensure your Supabase "URL Configuration" allows http://localhost:5173 and your
# production origin as a redirect URL. Google OAuth is configured in the Supabase
# Auth providers panel. No additional env vars are required for auth/sync.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
